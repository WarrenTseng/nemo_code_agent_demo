# Copy to .env and fill in values. Never commit .env to source control.
#
# API KEY RULES
# -------------
# - Cloud endpoints (NIM, OpenAI): set to your real key  (nvapi-... / sk-...)
# - Local endpoints (vLLM, Ollama): leave blank, omit entirely, or set to any
#   non-empty placeholder ("none", "local", "x") — the agent accepts all of these.
#   Do NOT set to a boolean (true/false) — .env files have no boolean type;
#   everything is a string, and the OpenAI SDK requires a non-empty string.

# --- Planner LLM (large reasoning model) ---
PLANNER_URL=https://integrate.api.nvidia.com/v1
PLANNER_MODEL=nvidia/nemotron-3-nano-30b-a3b # nvidia/nemotron-3-super-120b-a12b
PLANNER_API_KEY=nvapi-...                    # leave blank or omit for local endpoints
PLANNER_TEMPERATURE=0.2
PLANNER_MAX_TOKENS=16384
# --- Coder LLM (code-specialist model) ---
CODER_URL=https://integrate.api.nvidia.com/v1
CODER_MODEL=nvidia/nemotron-3-nano-30b-a3b   # qwen/qwen3-coder-480b-a35b-instruct
CODER_API_KEY=nvapi-...                      # leave blank or omit for local endpoints
CODER_TEMPERATURE=0.1
CODER_MAX_TOKENS=16384

ENABLE_CODER=true                     # set to false to let the Planner write code directly (no coder_tool)


# --- Agent state ---
CODE_AGENT_CHECKPOINT_DB=.agent_logs/checkpoints.db
CODE_AGENT_LOG_DIR=.agent_logs

# --- Knowledge base (static rules + RAG) ---
# When ENABLE_CODER=true  → knowledge is injected into coder_tool at generation time.
# When ENABLE_CODER=false → knowledge is injected into the Planner context each turn.
# Set ENABLE_KNOWLEDGE=false to disable all knowledge injection globally.
ENABLE_KNOWLEDGE=true
# strategy 1: place project-specific guidelines in knowledge/static.md (auto-detected)
# strategy 2: place .md files in knowledge/RAG/ and enable RAG below
CODER_KNOWLEDGE_DIR=knowledge          # dir containing static.md and RAG/

CODER_RAG_ENABLED=false               # set to true to enable RAG retrieval
# memory (default) = in-memory, rebuilt every session
# chroma           = persisted to knowledge/.chromadb/, skips re-embedding if unchanged
CODER_RAG_STORE=chroma
CODER_EMBEDDING_URL=https://integrate.api.nvidia.com/v1
CODER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
CODER_EMBEDDING_API_KEY=nvapi-...
# asymmetric (default) = passage/query routing required by NIM asymmetric models
# symmetric            = no input_type (for models that don't require it)
CODER_EMBEDDING_INPUT_TYPE=asymmetric
CODER_RAG_TOP_K=5                     # number of chunks to retrieve
CODER_RAG_CHUNK_SIZE=500
CODER_RAG_CHUNK_OVERLAP=50

# --- Long-context stability (optional — defaults shown) ---
AGENT_SUMMARIZE_THRESHOLD=20  # summarise when message history exceeds this count
AGENT_KEEP_AFTER_SUMMARY=6    # recent messages to keep after summarising
AGENT_TRIM_FOR_LLM=30         # hard cap on messages fed to the LLM per turn
AGENT_REINFORCE_AFTER=2       # inject tool-use reminder after this many consecutive tool steps
AGENT_MAX_TOOL_STEPS=20       # force final answer after this many total tool calls per turn
AGENT_RECURSION_LIMIT=50      # LangGraph recursion limit (default 25 is too low for complex tasks)

# --- NeMo Guardrails (optional LLM-based safety layer) ---
# Requires: pip install -e ".[guardrails]"
# GUARDRAILS_ENABLED=true
