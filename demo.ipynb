        "[![Open In Colab](https://colab.research.google.com/assets/colab-badge.svg)](https://colab.research.google.com/github/WarrenTseng/nemo_code_agent_demo/blob/main/demo.ipynb)\n",
        "\n",
        "# NeMo Code Agent Demo\n",
        "\n",
        "Interactive multi-agent CLI coding assistant powered by NVIDIA NIM.\n",
        "\n",
        "**Architecture:**\n",
        "- **Planner** — large reasoning model (Nemotron) that plans and orchestrates tools\n",
        "- **Coder** — code-specialist model (Qwen2.5-Coder) that generates code on demand\n",
        "- **Tools** — `read_file`, `write_file`, `execute_bash`, `coder_tool`\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Gowcr8CrbVV9"
      },
      "source": [
        "## 1. Install"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "ai4eKkAwbVV9"
      },
      "outputs": [],
      "source": [
        "import os\n",
        "\n",
        "REPO_URL = \"https://github.com/WarrenTseng/nemo_code_agent_demo.git\"\n",
        "REPO_DIR = \"nemo_code_agent_demo\"\n",
        "\n",
        "if not os.path.exists(REPO_DIR):\n",
        "    !git clone {REPO_URL}\n",
        "\n",
        "%cd {REPO_DIR}\n",
        "!pip install -e \".\" -q\n",
        "!pip install nest_asyncio -q\n",
        "print(\"Installation complete.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "0t6jigTEbVV-"
      },
      "source": [
        "## 2. Configure API Keys\n",
        "\n",
        "- Restart this session to apply changes and ensure nemo_code_agent is correctly configured.\n",
        "- Fill in your [NVIDIA NIM](https://build.nvidia.com) API key and model endpoints below, then run the cell."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "REPO_DIR = \"nemo_code_agent_demo\"\n",
        "%cd {REPO_DIR}"
      ],
      "metadata": {
        "id": "g0xDeq80gWlT"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "bA5guMUmbVV_"
      },
      "outputs": [],
      "source": [
        "# ── Fill in your values here ──────────────────────────────────────────────────\n",
        "PLANNER_URL       = \"https://integrate.api.nvidia.com/v1\"\n",
        "PLANNER_MODEL     = \"nvidia/nemotron-3-nano-30b-a3b\"\n",
        "PLANNER_API_KEY   = \"nvapi-...\"   # your NIM API key\n",
        "\n",
        "CODER_URL         = \"https://integrate.api.nvidia.com/v1\"\n",
        "# if this endpoint is not stable, please change to \"nvidia/nemotron-3-nano-30b-a3b\" for this demo\n",
        "CODER_MODEL       = \"qwen/qwen2.5-coder-32b-instruct\"\n",
        "CODER_API_KEY     = \"nvapi-...\"   # same key, or a different one\n",
        "# ─────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "env_content = f\"\"\"PLANNER_URL={PLANNER_URL}\n",
        "PLANNER_MODEL={PLANNER_MODEL}\n",
        "PLANNER_API_KEY={PLANNER_API_KEY}\n",
        "\n",
        "CODER_URL={CODER_URL}\n",
        "CODER_MODEL={CODER_MODEL}\n",
        "CODER_API_KEY={CODER_API_KEY}\n",
        "\"\"\"\n",
        "\n",
        "with open(\".env\", \"w\") as f:\n",
        "    f.write(env_content)\n",
        "\n",
        "print(\".env written.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Hn332oJ7bVV_"
      },
      "source": [
        "## 3. Start the Agent\n",
        "\n",
        "Run the cell below to start an interactive chat session.\n",
        "\n",
        "- Type your message and press **Enter** to send\n",
        "- When the agent wants to run a shell command, type **`y`** to approve or **`n`** to decline\n",
        "- Type **`exit`** to end the session"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "wJ7f3hkYbVV_"
      },
      "outputs": [],
      "source": [
        "import asyncio\n",
        "import os\n",
        "import sys\n",
        "\n",
        "import nest_asyncio\n",
        "nest_asyncio.apply()\n",
        "\n",
        "from dotenv import load_dotenv\n",
        "load_dotenv(override=True)\n",
        "\n",
        "from nemo_code_agent.workflow import create_agent\n",
        "from nemo_code_agent.guardrails import apply_guardrails\n",
        "from nemo_code_agent.tools import filesystem as _fs\n",                                                                   
        "\n",
        "_fs.set_auto_approve(True)\n"
        "\n",
        "SESSION_ID = \"colab-demo\"\n",
        "\n",
        "\n",
        "async def _stream_turn(agent, user_input: str, config: dict) -> None:\n",
        "    \"\"\"Stream a single agent turn, printing tokens as they arrive.\"\"\"\n",
        "    response_buffer = []\n",
        "    in_thinking = False\n",
        "    emitted_prefix = False\n",
        "    current_tool = None\n",
        "\n",
        "    print()  # blank line before agent output\n",
        "\n",
        "    async for event in agent.astream_events(\n",
        "        {\"messages\": [(\"user\", user_input)]},\n",
        "        config=config,\n",
        "        version=\"v2\",\n",
        "    ):\n",
        "        kind = event[\"event\"]\n",
        "        node = event.get(\"metadata\", {}).get(\"langgraph_node\", \"\")\n",
        "\n",
        "        # ── Planner tokens ──────────────────────────────────────────────────\n",
        "        if kind == \"on_chat_model_stream\" and node == \"planner\":\n",
        "            chunk = event[\"data\"][\"chunk\"]\n",
        "\n",
        "            thinking = chunk.additional_kwargs.get(\"reasoning_content\", \"\")\n",
        "            if thinking:\n",
        "                if not in_thinking:\n",
        "                    print(\"\\n⟨thinking⟩ \", end=\"\", flush=True)\n",
        "                    in_thinking = True\n",
        "                print(thinking, end=\"\", flush=True)\n",
        "\n",
        "            content = chunk.content or \"\"\n",
        "            if content:\n",
        "                if in_thinking:\n",
        "                    print(\"\\n⟨/thinking⟩\\n\", flush=True)\n",
        "                    in_thinking = False\n",
        "                if not emitted_prefix:\n",
        "                    print(\"Agent ❯ \", end=\"\", flush=True)\n",
        "                    emitted_prefix = True\n",
        "                print(content, end=\"\", flush=True)\n",
        "                response_buffer.append(content)\n",
        "\n",
        "        # ── Tool events ─────────────────────────────────────────────────────\n",
        "        elif kind == \"on_tool_start\":\n",
        "            if in_thinking:\n",
        "                print(\"\\n⟨/thinking⟩\\n\", flush=True)\n",
        "                in_thinking = False\n",
        "            current_tool = event[\"name\"]\n",
        "            tool_input = str(event[\"data\"].get(\"input\", {}))\n",
        "            preview = tool_input[:200] + \" …\" if len(tool_input) > 200 else tool_input\n",
        "            print(f\"\\n{'─'*60}\")\n",
        "            print(f\"▶ {current_tool}\")\n",
        "            print(preview)\n",
        "\n",
        "        elif kind == \"on_tool_end\":\n",
        "            print(f\"{'─'*60}\\n\")\n",
        "            current_tool = None\n",
        "            emitted_prefix = False\n",
        "\n",
        "    # ── Post-stream: guardrails ──────────────────────────────────────────────\n",
        "    full_response = \"\".join(response_buffer)\n",
        "    print()  # newline after streamed tokens\n",
        "\n",
        "    if full_response.strip():\n",
        "        _, was_blocked = await apply_guardrails(full_response)\n",
        "        if was_blocked:\n",
        "            print(\"\\n⚠ Safety Check: response withheld by guardrails.\")\n",
        "    elif not in_thinking:\n",
        "        print(\"[Agent completed without text response]\")\n",
        "\n",
        "\n",
        "async def run_chat() -> None:\n",
        "    print(\"╔══════════════════════════════════════╗\")\n",
        "    print(\"║       NeMo Code Agent — Colab        ║\")\n",
        "    print(f\"║  Session: {SESSION_ID:<26}║\")\n",
        "    print(\"║  Type 'exit' to end the session.     ║\")\n",
        "    print(\"╚══════════════════════════════════════╝\\n\")\n",
        "\n",
        "    config = {\"configurable\": {\"thread_id\": SESSION_ID}}\n",
        "\n",
        "    async with create_agent(checkpoint_db=\".agent_logs/checkpoints.db\") as agent:\n",
        "        while True:\n",
        "            try:\n",
        "                user_input = input(\"You ❯ \").strip()\n",
        "            except (EOFError, KeyboardInterrupt):\n",
        "                print(\"\\nGoodbye.\")\n",
        "                break\n",
        "\n",
        "            if not user_input:\n",
        "                continue\n",
        "            if user_input.lower() in (\"exit\", \"quit\", \"q\"):\n",
        "                print(\"Goodbye.\")\n",
        "                break\n",
        "\n",
        "            try:\n",
        "                await _stream_turn(agent, user_input, config)\n",
        "            except KeyboardInterrupt:\n",
        "                print(\"\\n⊘ Interrupted — returning to prompt.\\n\")\n",
        "\n",
        "\n",
        "asyncio.run(run_chat())"
      ]
    },
